{
  "openapi": "3.0.0",
  "info": {
    "title": "Dhammapeta Photographers Association Management API",
    "version": "1.0.0",
    "description": "Production-grade MVC REST API engine connected to Supabase PostgreSQL infrastructure."
  },
  "servers": [
    {
      "url": "http://localhost:5000/api/v1",
      "description": "Local Development Application Cluster Environment"
    }
  ],
  "paths": {
    "/funds/collect": {
      "post": {
        "summary": "Record a standardized Yearly Fund contribution transaction",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["financialYearId", "memberId", "amountPaid", "paymentMode"],
                "properties": {
                  "financialYearId": { "type": "integer" },
                  "memberId": { "type": "integer" },
                  "femaleBb": { "type": "number", "default": 0 },
                  "maleBb": { "type": "number", "default": 0 },
                  "idCardFee": { "type": "number", "default": 0 },
                  "amountPaid": { "type": "number" },
                  "paymentMode": { "type": "string", "enum": ["Cash", "UPI", "Bank Transfer"] },
                  "remarks": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Fund collection transaction written to ledger securely." },
          "401": { "description": "Bearer token invalid or missing." }
        }
      }
    },
    "/loans/issue": {
      "post": {
        "summary": "Provision a structured credit loan lifecycle matrix",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["financialYearId", "memberId", "loanType", "loanAmount", "interestRate", "installments"],
                "properties": {
                  "financialYearId": { "type": "integer" },
                  "memberId": { "type": "integer" },
                  "loanType": { "type": "string", "enum": ["Personal", "Emergency", "Equipment"] },
                  "loanAmount": { "type": "number" },
                  "interestRate": { "type": "number" },
                  "installments": { "type": "integer" },
                  "guarantorId": { "type": "integer" },
                  "remarks": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Loan issued and installment amortization schedule active." }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  }
}
