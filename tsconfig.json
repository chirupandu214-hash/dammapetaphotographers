{
  "compilerOptions": {
    "target": "ES2020",
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ES2020"
    ],

    "module": "ESNext",
    "moduleResolution": "Bundler",

    "baseUrl": ".",

    "paths": {
      "@/*": [
        "src/*"
      ]
    },

    "jsx": "react-jsx",

    "strict": true,
    "skipLibCheck": true,

    "noEmit": true,

    "resolveJsonModule": true,
    "isolatedModules": true,

    "types": [
      "vite/client"
    ]
  },

  "include": [
    "src"
  ]
}
